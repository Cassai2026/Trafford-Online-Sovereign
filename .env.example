# Trafford Online Sovereign OS — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to Git.

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://sovereign:CHANGE_ME@localhost:5432/trafford_sovereign
POSTGRES_PASSWORD=CHANGE_ME

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars
GOOGLE_CLIENT_ID=your-google-oauth2-client-id.apps.googleusercontent.com

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
API_BASE_URL=http://localhost:4000/api

# ── Service Swap proximity matching ──────────────────────────
# Maximum radius (km) when lat/lng are supplied to GET /swaps/match
SWAP_RADIUS_KM=10

# ── Safety report notifications ──────────────────────────────
# Webhook URL called when a critical safety report is created.
# Use a Slack incoming webhook, Make/Zapier HTTP endpoint, or custom handler.
GUARDIAN_WEBHOOK_URL=

# ── Redis (optional — enables multi-instance SSE pub/sub) ────
# Leave blank for single-instance / development deployments.
REDIS_URL=

# ── Edge controller ───────────────────────────────────────────
# URL of the Hub API accessible from the edge controller machine.
HUB_URL=http://localhost:4000/api
# Long-lived service token issued to the edge controller for /vajra/ack.
HUB_ACK_TOKEN=

# ── Discourse ────────────────────────────────────────────────
DISCOURSE_HOSTNAME=forum.trafford.online
DISCOURSE_DEVELOPER_EMAILS=admin@trafford.online
DISCOURSE_ADMIN_PASSWORD=CHANGE_ME

# ── Nextcloud ────────────────────────────────────────────────
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME
NEXTCLOUD_TRUSTED_DOMAINS=files.trafford.online
